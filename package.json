{
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ACME protocol library and private certificate authority",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rimraf node_modules",
    "cspell": "cspell --config internal/build/cspell.json --gitignore --no-progress '**'",
    "dev:prepare": "pnpm -r dev:prepare",
    "lint": "run-s lint:root cspell lint:_packages",
    "lint:_packages": "pnpm -r lint",
    "lint:check": "run-s lint:root:check cspell lint:check:_packages",
    "lint:check:_packages": "pnpm -r lint:check",
    "lint:root": "eslint --fix --ignore-pattern 'packages/*' .",
    "lint:root:check": "eslint --ignore-pattern 'packages/*' .",
    "precommit": "run-s dev:prepare lint type-check build test",
    "prepack": "run-s lint:root:check prepack:_packages",
    "prepack:_packages": "pnpm -r prepack",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@poupe/eslint-config": "~0.9.1",
    "cspell": "^10.0.0",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "pkg-pr-new": "~0.0.70",
    "rimraf": "^6.1.3"
  },
  "packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7"
}
