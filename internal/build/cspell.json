{
  "version": "0.2",
  "language": "en-GB",
  "ignorePaths": [
    "**/docs/rfc/**",
    "**/pnpm-lock.yaml"
  ],
  "ignoreRegExpList": [
    "/['\"`][A-Za-z0-9+/_=.-]{16,}['\"`]/g",
    "/['\"`]eyJ[A-Za-z0-9+/_=.-]{4,}['\"`]/g"
  ],
  "words": [
    "ALPN",
    "apptly",
    "assignability",
    "base64url",
    "certbot",
    "consola",
    "dnsname",
    "ECJWK",
    "ecdsa",
    "eddsa",
    "extn",
    "hermeticity",
    "jose",
    "kagal",
    "merkle",
    "miniflare",
    "OCSP",
    "OKPJWK",
    "picklist",
    "pkijs",
    "poupe",
    "precert",
    "precertificate",
    "prepack",
    "resumable",
    "RSAJWK",
    "rsassa",
    "subproblem",
    "subproblems",
    "thumbprint",
    "thumbprinting",
    "TLSALPN",
    "tsdocs",
    "tsyringe",
    "unbuild",
    "valibot",
    "webcrypto",
    "whatwg",
    "workerd",
    "wrangler"
  ],
  "overrides": [
    {
      "filename": ["**/cspell.json", "**/package.json"],
      "words": ["letsencrypt"]
    }
  ]
}
