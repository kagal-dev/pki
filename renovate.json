{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "groupName": "Cloudflare",
      "groupSlug": "cloudflare",
      "matchPackageNames": [
        "@cloudflare/**",
        "wrangler",
        "miniflare"
      ]
    }, {
      "groupName": "eslint dependencies",
      "groupSlug": "eslint",
      "matchPackageNames": [
        "/eslint/"
      ]
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "rangeStrategy": "bump"
}
